.detail-nav {
  padding-top: 20rpx;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.detail-art {
  height: 620rpx;
}

.detail-art .turtle {
  left: 190rpx;
  top: 230rpx;
  transform: scale(1.7);
  transform-origin: center;
}

.detail-art .spark {
  left: 38rpx;
  top: 38rpx;
}

.detail-art .spark.two {
  right: 42rpx;
  bottom: 44rpx;
  left: auto;
  top: auto;
}

.raw-chip {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  min-height: 76rpx;
  padding: 0 26rpx;
  border: 0;
  border-radius: 999rpx;
  background: rgba(32, 36, 33, .82);
  color: #fffef9;
  font-size: 24rpx;
  font-weight: 800;
}

.result-card {
  margin-top: 26rpx;
  padding: 34rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.name {
  font-size: 46rpx;
  font-weight: 850;
  line-height: 1.16;
}

.latin {
  margin-top: 8rpx;
  color: #9aa098;
  font-size: 24rpx;
  font-style: italic;
}

.confidence {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(90, 167, 118, .14);
  color: #397550;
  font-size: 22rpx;
  font-weight: 800;
}

.summary {
  margin: 26rpx 0;
  color: #3f3a34;
  font-size: 28rpx;
  line-height: 1.6;
}

.fact {
  padding-top: 22rpx;
  border-top: 1rpx solid #e7e1d7;
}

.fact + .fact {
  margin-top: 20rpx;
}

.fact-title {
  margin-bottom: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.fact-text {
  color: #646a63;
  font-size: 26rpx;
  line-height: 1.55;
}

.video-preview {
  position: fixed;
  inset: 0;
  z-index: 20;
  padding: 60rpx 30rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, .72);
  display: flex;
  align-items: center;
}

.video-shell {
  width: 100%;
}

.video {
  width: 100%;
  height: 720rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background: #000;
}

.close {
  width: 100%;
  margin-top: 24rpx;
  background: #fffef9;
}
